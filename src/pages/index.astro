---
import { getCollection } from 'astro:content';
import CategoryCard from '../components/CategoryCard.astro';
import CategorySection from '../components/CategorySection.astro';
import SearchHero from '../components/SearchHero.astro';
import { docsCategories, docsParentCategories, getCategoryHref, getSearchPreviewLookup, getSuggestedSearchArticles } from '../data/docs';
import Layout from '../layouts/Layout.astro';
import site from '../../site.config.mjs';

const allDocs = await getCollection('docs');
const suggestedArticles = getSuggestedSearchArticles(allDocs);
const searchPreviews = getSearchPreviewLookup(allDocs);

// [left%, top%, size-px, duration-s, delay-s, opacity, drift-px]
const sparkleData: [number, number, number, number, number, number, number][] = [
  [6,  22, 5, 4.5,  0.0, 0.80,  6],
  [14, 71, 3, 6.2, -1.4, 0.65, -4],
  [21, 38, 6, 5.0, -2.8, 0.75,  8],
  [29, 12, 3, 7.0, -0.6, 0.60, -6],
  [35, 83, 5, 4.8, -3.5, 0.70,  4],
  [43, 55, 7, 6.5, -1.8, 0.55, -8],
  [50, 28, 3, 5.5, -4.2, 0.80,  6],
  [57, 67, 5, 4.2, -0.9, 0.70, -4],
  [64, 16, 6, 6.8, -2.2, 0.65,  8],
  [71, 46, 3, 5.2, -3.8, 0.75, -6],
  [78, 78, 5, 4.6, -1.1, 0.65,  4],
  [85, 31, 6, 7.2, -2.6, 0.55, -8],
  [91, 57, 3, 5.8, -4.6, 0.70,  6],
  [10, 91, 5, 6.0, -0.3, 0.60, -4],
  [47, 88, 3, 5.0, -2.0, 0.65,  8],
  [72,  8, 5, 4.9, -3.2, 0.75, -4],
  [26, 48, 3, 6.3, -1.7, 0.60,  6],
  [88,  4, 6, 5.7, -4.0, 0.70, -6],
  [3,  55, 4, 5.3, -2.5, 0.65,  5],
  [96, 40, 3, 6.7, -1.0, 0.60, -5],
  [38,  5, 5, 4.4, -3.8, 0.72,  7],
  [60, 95, 4, 5.9, -0.7, 0.65, -7],
];
---

<Layout title={`${site.title} | Astro docs theme`} description={site.description}>
  <SearchHero suggestions={suggestedArticles} searchPreviews={searchPreviews} />

  <div class="relative py-8 md:py-10">
    <div class="sparkles-layer" aria-hidden="true">
      {sparkleData.map(([left, top, size, duration, delay, opacity, drift]) => (
        <span
          class="sparkle-dot"
          style={`left:${left}%;top:${top}%;width:${size}px;height:${size}px;animation-duration:${duration}s;animation-delay:${delay}s;--sparkle-opacity:${opacity};--sparkle-drift:${drift}px`}
        />
      ))}
    </div>
    {docsParentCategories.map((parent) => (
      <CategorySection slug={parent.slug} title={parent.name} description={parent.description}>
        {docsCategories
          .filter((category) => category.parent === parent.slug)
          .map((category) => {
            const count = allDocs.filter((doc) => doc.data.category === category.slug).length;

            return (
              <CategoryCard
                title={category.name}
                description={category.description}
                count={count}
                href={getCategoryHref(category.slug)}
                icon={category.icon}
              />
            );
          })}
      </CategorySection>
    ))}
  </div>
</Layout>
